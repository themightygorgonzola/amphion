# =============================================================================
# AMPHION — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real values.
# =============================================================================

# --- System Identity ---
# Internal system name (used in logs, process names)
SYSTEM_NAME=amphion
# Display name shown in the Electron UI and spoken by the voice layer
DISPLAY_NAME=Atlas
# User and company name — injected into the voice character prompt
USER_NAME=David
COMPANY_NAME=Acme Corp

# --- Broker ---
BROKER_PORT=3000
# Set to 0.0.0.0 to allow LAN access from other devices (phone, tablet)
BROKER_HOST=127.0.0.1

# --- Ollama ---
# Dev: points to mock-ollama container. Prod: points to real Ollama on GPU server.
OLLAMA_HOST=http://localhost:11434
# Voice synthesis — controls tone and narrative quality. Try: mistral-small3.1:24b, qwen2.5:72b, phi4:14b
OLLAMA_MODEL_VOICE=llama3.3:70b
# Dispatcher routing (structured JSON output — qwen3 excels here, do not swap lightly)
OLLAMA_MODEL_DISPATCHER=qwen3:14b
OLLAMA_MODEL_EMBED=nomic-embed-text
# Coding model — used by the Dev agent for self-augmentation
OLLAMA_MODEL_CODER=devstral

# --- PostgreSQL / pgvector ---
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=amphion
PGVECTOR_USER=amphion
PGVECTOR_PASSWORD=changeme_before_prod

# --- SQLite (short-term memory — conversation history + user context) ---
SQLITE_PATH=./data/memory.db

# --- Logging ---
# Options: debug | info | warn | error
LOG_LEVEL=info

# --- Feature Flags ---
# Set to true to enable voice output via Web Speech API
VOICE_ENABLED=true
# Set to true to enable the morning briefing cron job
BRIEFING_ENABLED=false
BRIEFING_TIME=08:00
