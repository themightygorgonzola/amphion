{
  "name": "amphion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "agents/*"
  ],
  "scripts": {
    "start": "node scripts/start.js",
    "start:no-restart": "node scripts/start.js --no-restart",
    "start:headless": "node scripts/start.js --headless",
    "dev": "docker compose -f infra/docker-compose.dev.yml up",
    "dev:down": "docker compose -f infra/docker-compose.dev.yml down",
    "dev:build": "docker compose -f infra/docker-compose.dev.yml up --build",
    "migrate": "node scripts/migrate.js",
    "ingest": "node scripts/ingest.js",
    "reset": "node scripts/reset.js",
    "seed": "node scripts/seed-context.js",
    "broker": "node apps/broker/src/index.js",
    "broker:dev": "nodemon apps/broker/src/index.js",
    "stage-watch": "node scripts/stage-watch.js",
    "watch-ingest": "node scripts/watch-ingest.js",
    "debug-query": "node scripts/debug-query.js",
    "desktop": "npx --no electron apps/desktop/src/main.js",
    "desktop:dev": "npx --no electron apps/desktop/src/main.js --dev",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
