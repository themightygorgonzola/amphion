{
  "name": "amphion",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "agents/*"
  ],
  "scripts": {
    "dev": "docker compose -f infra/docker-compose.dev.yml up",
    "dev:down": "docker compose -f infra/docker-compose.dev.yml down",
    "dev:build": "docker compose -f infra/docker-compose.dev.yml up --build",
    "migrate": "node scripts/migrate.js",
    "broker": "node apps/broker/src/index.js",
    "broker:dev": "nodemon apps/broker/src/index.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
